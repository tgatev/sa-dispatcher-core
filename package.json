{
  "name": "star-atlas-assistant",
  "module": "index.ts",
  "type": "module",
  "version": "4.0.0",
  "description": "Provide libraris and scripting for star atlass - starbased.",
  "scripts": {
    "build": "rm -rf dist && bun build --outdir=dist --sourcemap=external --target=node --splitting index.ts",
    "start": "bun run server.ts",
    "watch": "bun --watch server.ts",
    "cmd-center": "bun run cmd-center.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\""
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git://git@github.com:tgatev/sa-dispatcher.git"
  },
  "devDependencies": {
    "bun-types": "latest",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.8.2"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@project-serum/anchor": "0.25.0",
    "@solana/web3.js": "^1.98.2",
    "@staratlas/galactic-marketplace": "^0.11.4",
    "@staratlas/holosim": "npm:@staratlas/sage@1.9.0-alpha.12",
    "@staratlas/sage-main": "npm:@staratlas/sage@^1.8.*",
    "@types/bun": "^1.3.11",
    "@types/lodash": "^4.14.202",
    "@types/node-fetch": "^2.6.12",
    "bigint": "^0.4.2",
    "bigint-buffer": "^1.1.5",
    "bip39": "^3.1.0",
    "bs58": "^5.0.0",
    "chalk": "^5.3.0",
    "ed25519-hd-key": "^1.3.0",
    "moment": "^2.30.1",
    "moment-duration-format": "^2.3.2",
    "progress": "^2.0.3",
    "prompt-sync": "^4.2.0",
    "yargs": "^17.7.2"
  },
  "overrides": {
    "chalk": "5.3.0",
    "strip-ansi": "7.1.0",
    "color-convert": "2.0.1",
    "color-name": "1.1.4",
    "is-core-module": "2.13.1",
    "error-ex": "1.3.2",
    "has-ansi": "5.0.1"
  }
}
